rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net denying unmapped endpoints
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard helper operations
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Strict validation schema for user setting preferences and stats
    function isValidUser(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.email is string
        && data.email.size() <= 256
        && (!data.keys().hasAll(['focusDuration']) || data.focusDuration is number)
        && (!data.keys().hasAll(['shortBreakDuration']) || data.shortBreakDuration is number)
        && (!data.keys().hasAll(['longBreakDuration']) || data.longBreakDuration is number)
        && (!data.keys().hasAll(['dailyGoal']) || data.dailyGoal is number)
        && (!data.keys().hasAll(['theme']) || (data.theme is string && (data.theme == 'light' || data.theme == 'dark')))
        && (!data.keys().hasAll(['xp']) || data.xp is number)
        && (!data.keys().hasAll(['level']) || data.level is number);
    }

    // Validation for Pomodoro session activities
    function isValidActivity(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.userId is string
        && data.userId.size() <= 128
        && data.type is string
        && (data.type == 'focus' || data.type == 'short_break' || data.type == 'long_break')
        && data.duration is number
        && data.completed is bool
        && (!data.keys().hasAll(['taskName']) || (data.taskName is string && data.taskName.size() <= 500));
    }

    // Validation for Gamified badges
    function isValidBadge(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.userId is string
        && data.userId.size() <= 128
        && data.badgeId is string
        && data.badgeId.size() <= 128
        && data.title is string
        && data.title.size() <= 200;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.updatedAt == request.time;

      match /activities/{activityId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidActivity(request.resource.data) && request.resource.data.createdAt == request.time;
        allow update: if isOwner(userId) && isValidActivity(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /badges/{badgeId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBadge(request.resource.data) && request.resource.data.earnedAt == request.time;
        allow update: if isOwner(userId) && isValidBadge(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
